{
  "name": "pixel-scene-kit",
  "version": "0.2.0",
  "description": "An intuitive pixel framebuffer with canvas rendering and a tiny solid 3D engine.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "test:watch": "node --test --watch",
    "check": "node --check src/index.js && node --test"
  },
  "keywords": [
    "pixel",
    "framebuffer",
    "canvas",
    "graphics",
    "wireframe",
    "3d"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
